APP_NAME=Vision Capital AI
APP_ENV=local
APP_SECRET_KEY=change-me
AUTO_CREATE_TABLES=false
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/vision_capital_ai
REDIS_URL=redis://redis:6379/0
DATABASE_CONNECT_TIMEOUT_SECONDS=1

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
R2_PRESIGNED_URL_EXPIRY_SECONDS=900
UPLOAD_MULTIPART_THRESHOLD_BYTES=10485760
UPLOAD_PART_SIZE_BYTES=8388608
MAX_UPLOAD_SIZE_BYTES=1073741824
MAX_PARSE_RETRIES=3

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
OCR_MODEL=gpt-4o-mini
OCR_MAX_PAGES=20

LOCAL_STORAGE_PATH=./storage_data
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
EMBEDDING_DIMENSION=1536
CELERY_TASK_ALWAYS_EAGER=false
